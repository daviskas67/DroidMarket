<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/themeCardBgDrawable">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="12dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp">

        <ImageView
            android:id="@+id/app_icon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginRight="12dp"
            android:scaleType="fitCenter"
            android:background="?attr/themeCardBgAlt" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/app_name"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/themeTextPrimary"
                android:textSize="15sp"
                android:singleLine="true" />

            <TextView
                android:id="@+id/app_package"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/themeTextSecondary"
                android:textSize="11sp"
                android:singleLine="true"
                android:layout_marginTop="1dp" />

            <LinearLayout
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/app_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:paddingLeft="4dp"
                    android:paddingRight="4dp"
                    android:paddingTop="1dp"
                    android:paddingBottom="1dp"
                    android:background="#888888"
                    android:layout_marginRight="6dp"
                    android:visibility="gone" />

                <TextView
                    android:id="@+id/app_version"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/themeAccent"
                    android:textSize="12sp"
                    android:layout_marginRight="12dp" />

                <TextView
                    android:id="@+id/app_size"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/themeTextTertiary"
                    android:textSize="12sp"
                    android:layout_marginRight="12dp" />

                <TextView
                    android:id="@+id/app_android"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/themeTextTertiary"
                    android:textSize="12sp"
                    android:layout_marginRight="12dp" />
                <TextView
                    android:id="@+id/app_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="?attr/themeTextTertiary"
                    android:textSize="11sp" />
            </LinearLayout>

        </LinearLayout>
    </LinearLayout>

</LinearLayout>
