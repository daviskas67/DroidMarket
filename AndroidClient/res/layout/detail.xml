<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical"
    android:background="#ffeeeeee">

    <!-- Detail Header -->
    <RelativeLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:padding="12dp"
        android:background="#ffffffff">

        <ImageView
            android:id="@+id/detail_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:scaleType="fitCenter"
            android:background="#fff5f5f5" />

        <TextView
            android:id="@+id/detail_name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#ff404040"
            android:layout_toRightOf="@+id/detail_icon"
            android:layout_marginLeft="14dp"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:singleLine="true" />

        <TextView
            android:id="@+id/detail_package"
            android:textSize="13sp"
            android:textColor="#ff999999"
            android:layout_toRightOf="@+id/detail_icon"
            android:layout_below="@+id/detail_name"
            android:layout_marginLeft="14dp"
            android:layout_marginTop="2dp"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:singleLine="true" />

        <TextView
            android:id="@+id/detail_date"
            android:textSize="12sp"
            android:textColor="#ff999999"
            android:layout_toRightOf="@+id/detail_icon"
            android:layout_below="@+id/detail_package"
            android:layout_marginLeft="14dp"
            android:layout_marginTop="2dp"
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:visibility="gone" />
    </RelativeLayout>

    <!-- Stats -->
    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#ffffffff"
        android:layout_marginTop="1px"
        android:gravity="center">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/detail_downloads"
                android:textSize="22sp"
                android:textColor="#ff96aa39"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <TextView
                android:text="@string/downloads"
                android:textSize="12sp"
                android:textColor="#ff999999"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/detail_versions_count"
                android:textSize="22sp"
                android:textColor="#ff96aa39"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <TextView
                android:text="@string/versions"
                android:textSize="12sp"
                android:textColor="#ff999999"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Section: Versions -->
    <TextView
        android:id="@+id/versions_header"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="12dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:paddingRight="12dp"
        android:textSize="13sp"
        android:textColor="#ffffffff"
        android:background="#ffbfbfbf"
        android:textStyle="bold"
        android:text="VERSIONS" />

    <ListView
        android:id="@+id/version_list"
        android:layout_width="fill_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@android:color/transparent"
        android:dividerHeight="0dp"
        android:listSelector="@android:drawable/list_selector_background"
        android:cacheColorHint="#ffeeeeee" />

</LinearLayout>
