<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical"
    android:background="?attr/themeBackground">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="?attr/themeCardBgDrawable">

        <ImageView
            android:id="@+id/detail_icon"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_marginRight="16dp"
            android:scaleType="fitCenter"
            android:background="?attr/themeCardBgAlt" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/detail_name"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/themeTextPrimary"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/detail_package"
                android:layout_width="fill_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/themeTextSecondary"
                android:textSize="12sp"
                android:singleLine="true"
                android:layout_marginTop="2dp" />

        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/detail_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="?attr/themeTextTertiary"
        android:textSize="11sp"
        android:paddingLeft="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp"
        android:background="?attr/themeCardBgDrawable"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingTop="12dp"
        android:paddingBottom="12dp"
        android:background="?attr/themeCardBgDrawable">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/detail_versions_count"
                android:textSize="22sp"
                android:textColor="?attr/themeAccent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <TextView
                android:text="@string/versions"
                android:textSize="11sp"
                android:textColor="?attr/themeTextTertiary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:id="@+id/detail_downloads"
                android:textSize="22sp"
                android:textColor="?attr/themeAccent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
            <TextView
                android:text="@string/downloads"
                android:textSize="11sp"
                android:textColor="?attr/themeTextTertiary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/versions_header"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        android:paddingLeft="16dp"
        android:paddingTop="12dp"
        android:paddingRight="16dp"
        android:paddingBottom="12dp"
        android:textSize="14sp"
        android:textColor="?attr/themeAccent"
        android:background="?attr/themeCardBgDrawable" />

    <ListView
        android:id="@+id/version_list"
        android:layout_width="fill_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="?attr/themeDivider"
        android:dividerHeight="1px"
        android:listSelector="@android:drawable/list_selector_background"
        android:cacheColorHint="?attr/themeBackground" />

</LinearLayout>
