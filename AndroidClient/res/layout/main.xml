<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:orientation="vertical"
    android:background="?attr/themeBackground">

    <LinearLayout
        android:layout_width="fill_parent"
        android:layout_height="48dp"
        android:background="?attr/themeActionbarBg"
        android:gravity="center_vertical"
        android:paddingLeft="16dp"
        android:paddingRight="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/app_name"
            android:textColor="?attr/themeTextPrimary"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/count_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:background="?attr/themeCountBg"
            android:textColor="?attr/themeTextSecondary"
            android:textSize="11sp" />
    </LinearLayout>

    <EditText
        android:id="@+id/search_input"
        android:layout_width="fill_parent"
        android:layout_height="40dp"
        android:hint="@string/search_hint"
        android:paddingLeft="12dp"
        android:paddingRight="12dp"
        android:background="?attr/themeSearchBg"
        android:textColor="?attr/themeSearchText"
        android:textColorHint="?attr/themeSearchHint"
        android:textSize="14sp"
        android:singleLine="true" />

    <ListView
        android:id="@android:id/list"
        android:layout_width="fill_parent"
        android:layout_height="fill_parent"
        android:layout_weight="1"
        android:divider="?attr/themeDivider"
        android:dividerHeight="1px"
        android:listSelector="@android:drawable/list_selector_background"
        android:cacheColorHint="?attr/themeBackground"
        android:paddingTop="0dp"
        android:paddingBottom="0dp" />

    <Button
        android:id="@+id/retry_button"
        android:layout_width="fill_parent"
        android:layout_height="48dp"
        android:text="@string/retry"
        android:textColor="?attr/themeAccent"
        android:background="?attr/themeCardBg"
        android:visibility="gone"
        android:textSize="14sp" />

</LinearLayout>
